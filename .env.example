# KHOJO — Environment Configuration
# Copy to .env (backend) and frontend/.env.local before running locally.

# ─── AI providers — all free tier ─────────────────────────────────────────
# Hugging Face Inference API — primary face-aging provider.
# Create a free token at https://huggingface.co/settings/tokens (read scope).
HF_TOKEN=hf_your_hf_token
HF_AGING_MODEL=nateraw/sam

# Self-hosted Colab fallback (optional). If you run the face-aging notebook
# in Google Colab and expose it via ngrok, paste the public URL here.
# Leave blank to skip this provider.
COLAB_AGING_URL=

# Groq — free LLM fallback (OpenAI-compatible API, Llama 3.3 70B).
# Get a key at https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_key
GROQ_MODEL=llama-3.3-70b-versatile

# OpenAI — primary LLM (hackathon-provided credits).
OPENAI_API_KEY=sk-proj-your_openai_key
OPENAI_MODEL=gpt-4o
OPENAI_PROMPT_VERSION=v1

# Master toggles.
GPT4O_ENABLED=true
USE_MOCK_AI=false

# ─── Supabase (Postgres + pgvector + Auth + Storage) ─────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ-your-anon-key
SUPABASE_SERVICE_KEY=eyJ-your-service-role-key
SUPABASE_BUCKET_CASE_PHOTOS=case-photos
SUPABASE_BUCKET_NOT_MATCH_PHOTOS=not-match-photos

# ─── Database ─────────────────────────────────────────────────────────────
# Use the Supabase connection pooler URL in production.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/khojo

# ─── Audit signing (HMAC-SHA256 over tamper-evident log, FRS §10.3) ──────
# Generate with: openssl rand -hex 32
AUDIT_SIGNING_SECRET=replace-with-64-char-random-string-generated-via-openssl-rand-hex-32

# ─── CORS ─────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,https://khojo.vercel.app

# ─── Auth ─────────────────────────────────────────────────────────────────
JWT_SECRET=replace-with-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# ─── Runtime ──────────────────────────────────────────────────────────────
ENVIRONMENT=development
# Railway / HF Spaces inject PORT automatically; leave unset locally to default to 8000.
# PORT=8000

# ─── Frontend (duplicate into frontend/.env.local, not loaded by backend) ─
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
