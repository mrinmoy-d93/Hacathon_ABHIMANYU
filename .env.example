# KHOJO — Environment Configuration
# Copy to .env (backend) and frontend/.env.local before running locally.

# ─── OpenAI (GPT-4o summaries + alert messages, FRS §6.3.9) ───────────────
OPENAI_API_KEY=sk-your-openai-key-here

# ─── Supabase (Postgres + pgvector + Auth + Storage) ─────────────────────
# Create a project at https://supabase.com → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ-your-anon-key
SUPABASE_SERVICE_KEY=eyJ-your-service-role-key
# Bucket names (public) created via Supabase → Storage
SUPABASE_BUCKET_CASE_PHOTOS=case-photos
SUPABASE_BUCKET_NOT_MATCH_PHOTOS=not-match-photos

# ─── Replicate (hosted InsightFace / ArcFace / SAM / HRFAE inference) ────
# https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=r8_your-replicate-token

# ─── Database ─────────────────────────────────────────────────────────────
# Use the Supabase connection pooler URL in production.
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/khojo

# ─── Audit signing (HMAC-SHA256 over tamper-evident log, FRS §10.3) ──────
# Generate with: openssl rand -hex 32
AUDIT_SIGNING_SECRET=replace-with-64-char-random-string-generated-via-openssl-rand-hex-32

# ─── CORS ─────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
CORS_ORIGINS=http://localhost:3000,https://khojo.vercel.app

# ─── Auth ─────────────────────────────────────────────────────────────────
JWT_SECRET=replace-with-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# ─── Runtime ──────────────────────────────────────────────────────────────
ENVIRONMENT=development
# Railway injects PORT automatically; leave unset locally to default to 8000.
# PORT=8000

# ─── Frontend (duplicate into frontend/.env.local, not loaded by backend) ─
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
